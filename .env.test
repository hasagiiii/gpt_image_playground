# 测试环境变量（vitest 默认 mode=test 会加载本文件）。
# Vite 中 .env.test 优先级高于 .env.local，用于把开发者本地 .env.local 的运行时
# 配置归一为干净默认值，使测试与本地配置解耦、CI 与本地结果一致。
# 需要特定取值的用例仍可用 vi.stubEnv + vi.resetModules 显式覆盖。
VITE_DEFAULT_API_URL=
VITE_SHOW_DEFAULT_CONFIG_ONLY=false
VITE_API_PROXY_AVAILABLE=false
VITE_API_PROXY_LOCKED=false
VITE_DOCKER_DEPLOYMENT=false
VITE_DOCKER_LEGACY_API_URL_USED=false
VITE_AUTH_BACKEND_URL=
