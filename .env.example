# 环境变量示例
# 复制为 .env.local（已被 .gitignore 忽略）后按需修改。
# 所有变量均为可选；不配置时使用代码内默认行为。

# ─────────────────────────────────────────────
# 认证（OIDC 登录）
# ─────────────────────────────────────────────
# 控制是否启用登录。未设置或留空的处理见下：
#   - 不设置该变量：禁用认证，直接进入首页（纯静态部署）
#   - ""（空串）  ：启用认证，使用同源后端（推荐生产部署，nginx 反代 /auth /api/v1）
#   - "disabled" ：显式禁用认证
#   - "https://..."：启用认证并跨域调用指定后端（开发环境常用）
# 启用后，进入首页时若无有效登录态会弹出登录弹窗。
VITE_AUTH_BACKEND_URL=

# ─────────────────────────────────────────────
# 默认 API 配置
# ─────────────────────────────────────────────
# 默认的 OpenAI 兼容 API 地址，留空则使用应用内置默认值。
VITE_DEFAULT_API_URL=

# 是否提供内置 API 代理（同源 /api-proxy 转发）。"true" 启用。
VITE_API_PROXY_AVAILABLE=false

# 是否锁定 API 代理（用户不可改为直连）。需 VITE_API_PROXY_AVAILABLE=true 才生效。
VITE_API_PROXY_LOCKED=false

# 是否仅展示默认配置（隐藏自定义供应商配置入口）。"true" 启用。
VITE_SHOW_DEFAULT_CONFIG_ONLY=false

# ─────────────────────────────────────────────
# Docker 部署标记（通常由部署脚本注入，本地一般无需设置）
# ─────────────────────────────────────────────
VITE_DOCKER_DEPLOYMENT=false
VITE_DOCKER_LEGACY_API_URL_USED=false
